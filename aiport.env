# Ambiente central dos serviços AIPort (Debian 13)
# Mantenha aqui apenas o que diverge do appsettings.json base ou o que é segredo de producao.

# Runtime
ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://0.0.0.0:5005

# Intelligence Service - Server
# Use estas variaveis apenas se quiser sobrescrever o bloco Server do appsettings.
# AIPORT_INTELLIGENCE_SERVER_URLS=http://0.0.0.0:5005
# AIPORT_INTELLIGENCE_URLS=http://0.0.0.0:5005
# AIPORT_INTELLIGENCE_SERVER_REQUEST_HEADERS_TIMEOUT_SECONDS=60
# AIPORT_INTELLIGENCE_SERVER_KEEP_ALIVE_TIMEOUT_SECONDS=120
# AIPORT_SERVER_REQUEST_HEADERS_TIMEOUT_SECONDS=60
# AIPORT_SERVER_KEEP_ALIVE_TIMEOUT_SECONDS=120

# Orchestrator - Server
# AIPORT_ORCHESTRATOR_SERVER_URLS=http://0.0.0.0:5000
# AIPORT_ORCHESTRATOR_URLS=http://0.0.0.0:5000
# AIPORT_ORCHESTRATOR_SERVER_REQUEST_HEADERS_TIMEOUT_SECONDS=60
# AIPORT_ORCHESTRATOR_SERVER_KEEP_ALIVE_TIMEOUT_SECONDS=120

# CORS do admin-portal publicado em :81
AIPORT_CORS_ALLOWED_ORIGINS=http://143.14.79.62:81

# Orchestrator
# Em producao o modo correto e Asterisk, enquanto o appsettings base esta apontando para WindowsVoice.
AIPORT_INPUT_SOURCE_MODE=Asterisk

# AGI
# AIPORT_AGI_ENABLED=true
# AIPORT_AGI_HOST=0.0.0.0
# AIPORT_AGI_PORT=4573
# AIPORT_AGI_BACKLOG=100

# Prefira loopback explicito no Debian para evitar resolucao inesperada de localhost.
AIPORT_INTELLIGENCE_BASE_URL=http://127.0.0.1:5005
# AIPORT_INTELLIGENCE_PROCESS_PATH=/api/inference/process

# Timeout de producao reduzido em relacao ao appsettings base do Orchestrator.
AIPORT_INTELLIGENCE_TIMEOUT_MS=45000
# AIPORT_INTELLIGENCE_MAX_RETRY_ATTEMPTS=3
# AIPORT_INTELLIGENCE_RETRY_BASE_DELAY_MS=200
AIPORT_WEBHOOK_TIMEOUT_MS=5000
# AIPORT_WEBHOOK_MAX_RETRY_ATTEMPTS=3
# AIPORT_WEBHOOK_RETRY_BASE_DELAY_MS=200

# Fallback routing
# AIPORT_FALLBACK_DATABASE_OFFLINE_EXTENSION=central

# Maintenance
# Habilite somente se quiser permitir ao portal-admin iniciar o monitor do orquestrador.
# Requer sudoers/NOPASSWD para o usuario do servico executar o comando abaixo sem prompt.
# AIPORT_MAINTENANCE_ENABLE_SERVICE_CONTROL=true
# AIPORT_MAINTENANCE_START_ORCHESTRATOR_MONITOR_COMMAND=sudo systemctl start aiport-orchestrator-healthcheck.timer

# Credencial sensivel e dependente do host.
AIPORT_MARIADB_CONNECTION_STRING=Server=127.0.0.1;Port=3306;Database=aiport;User ID=root;Password=root;AllowPublicKeyRetrieval=True;SslMode=None;

# Speech
# Necessario apenas se este host realmente usa streaming STT e credencial fora do padrao do deploy.
# AIPORT_TTS_PROVIDER=Google
# AIPORT_ASTERISK_TTS_APP=Festival
AIPORT_GOOGLE_CREDENTIALS_PATH=/opt/aiport/credentials/google_cloud_auth.json
AIPORT_GOOGLE_USE_STREAMING_STT=true
# AIPORT_GOOGLE_TEMP_DIRECTORY=/tmp
# AIPORT_GOOGLE_TTS_LANGUAGE_CODE=pt-BR
# AIPORT_GOOGLE_TTS_VOICE_NAME=pt-BR-Wavenet-A
# AIPORT_GOOGLE_TTS_SAMPLE_RATE_HZ=8000
# AIPORT_GOOGLE_TTS_SPEAKING_RATE=1.0
# AIPORT_GOOGLE_STT_LANGUAGE_CODE=pt-BR
# AIPORT_GOOGLE_STT_SAMPLE_RATE_HZ=8000

# Developer sandbox (normalmente nao usado em Debian)
# AIPORT_SANDBOX_TENANT_PID=200
# AIPORT_SANDBOX_CALLER_ID=DEV-LOCAL
# AIPORT_SANDBOX_CALLED_NUMBER=WINDOWS-SANDBOX
# AIPORT_SANDBOX_CONTEXT=developer-sandbox
# AIPORT_SANDBOX_SESSION_PREFIX=sandbox
# AIPORT_SANDBOX_DISABLE_WEBHOOK_CALLS=true
# AIPORT_SANDBOX_VERBOSE_CONSOLE_OUTPUT=true
# AIPORT_SANDBOX_WINDOWS_VOICE_PROVIDER=SystemSpeech
# AIPORT_SANDBOX_WINDOWS_VOICE_SUBSCRIPTION_KEY=
# AIPORT_SANDBOX_WINDOWS_VOICE_REGION=
# AIPORT_SANDBOX_WINDOWS_VOICE_LANGUAGE=pt-BR

# Intelligence Service
# Diverge do appsettings base: em producao voce quer threshold global 0.85 e SpaCy ligado.
AIPORT_AI_GLOBAL_CONFIDENCE_THRESHOLD=0.85
AIPORT_AI_NLP_USE_SPACY=true

# Regras e Regex
# AIPORT_AI_RULES_FILE_PATH=rules/tenant-rules.json
# AIPORT_AI_REGEX_ENABLED=true
# AIPORT_AI_REGEX_CONFIDENCE_THRESHOLD=0.85
# AIPORT_AI_REGEX_TIMEOUT_MS=100

# NLP
# AIPORT_AI_NLP_ENABLED=true
# AIPORT_AI_NLP_USE_EXTERNAL_API=true
# AIPORT_AI_NLP_EXTERNAL_API_BASE_URL=http://127.0.0.1:8010
# AIPORT_AI_NLP_EXTERNAL_API_TIMEOUT_MS=5000
# AIPORT_AI_NLP_EXTERNAL_API_KEY=
# AIPORT_AI_NLP_SPACY_PYTHON=python3
# AIPORT_AI_NLP_SPACY_MODEL=pt_core_news_sm
# AIPORT_AI_NLP_SPACY_TIMEOUT_MS=5000
# AIPORT_AI_NLP_USE_CATALYST=false
# AIPORT_AI_NLP_MODEL_LANGUAGE=pt
# AIPORT_AI_NLP_CONFIDENCE_THRESHOLD=0.70

# LLM
# AIPORT_AI_LLM_PROVIDER_TIMEOUT_SECONDS=30
# AIPORT_AI_LLM_TEMPERATURE=0.1
# AIPORT_AI_LLM_MAX_TOKENS=500
# AIPORT_AI_LLM_PRIMARY_NAME=Gemini-Primary
# AIPORT_AI_LLM_PRIMARY_SERVICE_TYPE=GoogleAI
# AIPORT_AI_LLM_PRIMARY_MODEL=gemini-2.5-flash
# AIPORT_AI_LLM_PRIMARY_DEPLOYMENT_NAME=
# AIPORT_AI_LLM_PRIMARY_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/
# AIPORT_AI_LLM_PRIMARY_ENABLED=true
# AIPORT_AI_LLM_PRIMARY_PRIORITY=1

# Segredo do provider principal.
AIPORT_AI_LLM_PRIMARY_API_KEY=AIzaSyBWNXhL-tZtAhO7-fJNPamAeFSRGX1MobA
GEMINI_API_KEY=AIzaSyBWNXhL-tZtAhO7-fJNPamAeFSRGX1MobA



