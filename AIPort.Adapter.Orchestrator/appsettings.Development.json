{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Server": {
    "Urls": "http://0.0.0.0:5000",
    "RequestHeadersTimeoutSeconds": 60,
    "KeepAliveTimeoutSeconds": 120
  },
  "AgiServer": {
    "Enabled": true,
    "Host": "0.0.0.0",
    "Port": 4573,
    "Backlog": 100
  },
  "IntelligenceService": {
    "BaseUrl": "http://localhost:5037",
    "ProcessPath": "/api/inference/process",
    "TimeoutMs": 8000,
    "MaxRetryAttempts": 3,
    "RetryBaseDelayMs": 200
  },
  "MariaDb": {
    "ConnectionString": "Server=localhost;Port=3306;Database=aiport;User ID=root;Password=root;AllowPublicKeyRetrieval=True;SslMode=None;"
  },
  "Webhook": {
    "TimeoutMs": 5000,
    "MaxRetryAttempts": 3,
    "RetryBaseDelayMs": 200
  },
  "Speech": {
    "TtsProvider": "Asterisk",
    "Asterisk": {
      "TtsApplication": "FLITE"
    },
    "Google": {
      "CredentialsPath": null,
      "TempDirectory": "/tmp",
      "TtsLanguageCode": "pt-BR",
      "TtsSampleRateHertz": 8000,
      "TtsSpeakingRate": 1.0,
      "SttLanguageCode": "pt-BR",
      "SttSampleRateHertz": 8000
    }
  }
}
