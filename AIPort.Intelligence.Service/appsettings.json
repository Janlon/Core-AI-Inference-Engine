{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AIPort.Intelligence.Service": "Information"
    }
  },
  "AllowedHosts": "*",

  "Server": {
    "Urls": "http://0.0.0.0:5005",
    "RequestHeadersTimeoutSeconds": 60,
    "KeepAliveTimeoutSeconds": 120
  },


  "AIService": {
    "GlobalConfidenceThreshold": 0.90,
    "RulesFilePath": "rules/tenant-rules.json",

    "Regex": {
      "Enabled": true,
      "ConfidenceThreshold": 0.85,
      "TimeoutMs": 100
    },

    "Nlp": {
      "Enabled": true,
      "UseExternalApi": true,
      "ExternalApiBaseUrl": "http://localhost:8010",
      "ExternalApiTimeoutMs": 3000,
      "ExternalApiKey": "",
      "UseSpacy": false,
      "SpacyPythonExecutable": "python3",
      "SpacyModel": "pt_core_news_sm",
      "SpacyTimeoutMs": 3000,
      "UseCatalyst": false,
      "ModelLanguage": "pt",
      "ConfidenceThreshold": 0.70
    },

    "Llm": {
      "Enabled": true,
      "ProviderTimeoutSeconds": 30,
      "Temperature": 0.1,
      "MaxTokens": 500
    },

    "LlmProviders": [
      {
        "Name": "Gemini-Primary",
        "ServiceType": "GoogleAI",
        "ApiKey": "sua_chave_aqui",
        "Model": "gemini-2.5-flash",
        "DeploymentName": "",
        "Endpoint": "https://generativelanguage.googleapis.com/v1beta/openai/",
        "IsEnabled": true,
        "Priority": 1
      },
      {
        "Name": "AzureOpenAI-Fallback",
        "ServiceType": "AzureOpenAI",
        "ApiKey": "",
        "Model": "gpt-4o",
        "DeploymentName": "gpt-4o",
        "Endpoint": "https://YOUR-RESOURCE.openai.azure.com/",
        "IsEnabled": false,
        "Priority": 2
      },
      {
        "Name": "OpenAI-Fallback",
        "ServiceType": "OpenAI",
        "ApiKey": "",
        "Model": "gpt-4o-mini",
        "Endpoint": "",
        "IsEnabled": false,
        "Priority": 3
      },
      {
        "Name": "Ollama-Local",
        "ServiceType": "Ollama",
        "ApiKey": "ollama",
        "Model": "llama3.1",
        "Endpoint": "http://localhost:11434",
        "IsEnabled": false,
        "Priority": 4
      }
    ]
  }
}

