{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning",
      "Microsoft.Extensions.Http.DefaultHttpClientFactory": "Warning",
      "AIPort.Intelligence.Service": "Information",
      "Microsoft.SemanticKernel": "Warning"
    }
  },
  "Server": {
    "Urls": "http://0.0.0.0:5005",
    "RequestHeadersTimeoutSeconds": 60,
    "KeepAliveTimeoutSeconds": 120
  },
  "AIService": {
    "GlobalConfidenceThreshold": 0.90,
    "Regex": {
      "Enabled": true,
      "ConfidenceThreshold": 0.85,
      "TimeoutMs": 100
    },
    "Nlp": {
      "Enabled": true,
      "UseExternalApi": true,
      "ExternalApiBaseUrl": "http://localhost:8010",
      "ExternalApiTimeoutMs": 5000,
      "ExternalApiKey": "",
      "UseSpacy": false,
      "SpacyPythonExecutable": "python",
      "SpacyModel": "pt_core_news_sm",
      "SpacyTimeoutMs": 5000,
      "UseCatalyst": false,
      "ModelLanguage": "pt",
      "ConfidenceThreshold": 0.70
    },
    "Llm": {
      "ProviderTimeoutSeconds": 30,
      "Temperature": 0.1,
      "MaxTokens": 500
    },
    "LlmProviders": [
      {
        "Name": "Ollama-Local",
        "ServiceType": "Ollama",
        "ApiKey": "ollama",
        "Model": "llama3.1",
        "Endpoint": "http://localhost:11434",
        "IsEnabled": true,
        "Priority": 1
      }
    ]
  }
}

