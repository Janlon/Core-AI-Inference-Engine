# Production environment variables

# MariaDB
MARIADB_ROOT_PASSWORD=root
MARIADB_PASSWORD=root

# ASP.NET Environment
ASPNETCORE_ENVIRONMENT=Production

# Backend API
BACKEND_PORT=5000
BACKEND_URL=http://127.0.0.1:5000

# Frontend
FRONTEND_PORT=81
FRONTEND_URL=http://127.0.0.1:81

# Vite frontend runtime
# Com o Nginx em :81 encaminhando /api para o orquestrador,
# o frontend deve usar mesmo host para evitar dependência de CORS.
VITE_API_BASE_URL=

# Intelligence Service
INTELLIGENCE_PORT=5005
INTELLIGENCE_URL=http://127.0.0.1:5005

# Asterisk AGI (se auto-hospedado)
ASTERISK_HOST=asterisk
ASTERISK_PORT=4573

# AGI Timeout settings
AGI_COMMAND_TIMEOUT=30
AGI_RECORD_TIMEOUT=300

# Webhook settings
WEBHOOK_TIMEOUT=2000
WEBHOOK_MAX_RETRIES=2

# Speech settings (TTS)
TTS_LANGUAGE=pt-BR
TTS_SAMPLE_RATE=8000
TTS_VOICE_NAME=pt-BR-female-1

# Speech settings (STT)
STT_USE_STREAMING=true
STT_LANGUAGE=pt-BR

# Logging
LOG_LEVEL=Information
LOG_PATH=/app/logs

# SSL/TLS (for production with nginx)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# Timezone
TZ=America/Sao_Paulo
